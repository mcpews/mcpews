{
    "name": "mcpews",
    "version": "4.0.2",
    "description": "A library that supports MCPE Websocket Protocol",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "bin": {
        "mcpews": "./dist/repl.js",
        "mcpewsmitm": "./dist/mitm.js"
    },
    "files": [
        "dist/"
    ],
    "scripts": {
        "clean": "rimraf ./dist",
        "build": "tsc",
        "lint": "biome check --write",
        "test": "node --no-warnings --experimental-vm-modules node_modules/jest/bin/jest.js",
        "watch": "tsc --watch --preserveWatchOutput"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/XeroAlpha/mcpews.git"
    },
    "keywords": [
        "minecraft",
        "bedrock",
        "websocket"
    ],
    "author": "ProjectXero",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/XeroAlpha/mcpews/issues"
    },
    "homepage": "https://github.com/XeroAlpha/mcpews",
    "dependencies": {
        "p-event": "^7.0.0",
        "ws": "^8.18.3"
    },
    "devDependencies": {
        "@biomejs/biome": "2.3.6",
        "@types/jest": "^30.0.0",
        "@types/node": "^24.10.1",
        "@types/ws": "^8.18.1",
        "jest": "^30.2.0",
        "rimraf": "^6.1.2",
        "ts-jest": "^29.4.5",
        "typedoc": "^0.28.14",
        "typescript": "^5.9.3"
    }
}
